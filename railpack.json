{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.13",
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        "pip install -r requirements.txt",
        "cd frontend && npm install"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "cd frontend && npm run build",
        "mkdir -p ../dist && cp -r frontend/dist/* ../dist/"
      ]
    }
  }
}
